# Browser requests. Keep `/api` when the frontend and API share one domain or reverse proxy.
VITE_API_BASE_URL=/api

# Dev-only Vite proxy target for `/api`, `/socket.io`, and `/uploads`.
VITE_API_PROXY_TARGET=http://localhost:4000

# Public landing page CTA target. Can be a contact form, mailto link, or future checkout URL.
VITE_REQUEST_ACCESS_URL=
