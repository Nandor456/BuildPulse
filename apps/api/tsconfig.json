{
  "compilerOptions": {
    "module": "NodeNext",
    "lib": ["ES2022"],
    "moduleResolution": "NodeNext",
    "target": "es2022",
    "esModuleInterop": true,
    "resolveJsonModule": true,
     "skipLibCheck": true,
    "strict": true,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": ["src"],
  "ts-node": {
    "files": true
  }
}
